{
  "name": "yeelight-tray",
  "version": "1.0.9",
  "description": "A tray-application for controlling Yeelight lights",
  "engines": {
    "node": "^22.20.0"
  },
  "scripts": {
    "dev": "electron-forge start",
    "lint": "eslint .",
    "start": "electron-forge start",
    "build:icons": "electron-icon-builder --flatten --input=./lightbulb.png --output=.",
    "package": "yarn build:icons && electron-forge package",
    "make": "electron-forge make",
    "release": "GITHUB_TOKEN=$(gh auth token) yarn release-it"
  },
  "main": ".vite/build/main.js",
  "author": "mitch@mitch-ryan.com",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@eslint/js": "^10.0.1",
    "@types/ms": "^2.1.0",
    "electron": "^41.1.1",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "release-it": "^19.2.4",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3"
  },
  "dependencies": {
    "ms": "^2.1.3",
    "polished": "^4.3.1",
    "rxjs": "^7.8.2",
    "zod": "^4.3.6"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "name": "Yeelight Tray",
        "executableName": "Yeelight Tray",
        "icon": "./icons/icon"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-vite",
          "config": {
            "build": [
              {
                "entry": "src/main.ts",
                "config": "vite.main.config.ts"
              },
              {
                "entry": "src/preload.ts",
                "config": "vite.preload.config.ts",
                "target": "preload"
              }
            ],
            "renderer": [
              {
                "name": "main_window",
                "config": "vite.renderer.config.ts"
              }
            ]
          }
        }
      ]
    }
  },
  "packageManager": "yarn@4.13.0"
}
